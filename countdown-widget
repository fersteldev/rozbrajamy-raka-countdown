<script>
const now = new Date();
const currentYear = now.getFullYear();
let endTime = new Date(currentYear, 5, 26, 18, 0, 0); 

if (now > endTime) {
    endTime = new Date(currentYear + 1, 5, 26, 18, 0, 0);
}

function updateCountdown() {
    const now = new Date();
    let diff = endTime - now;

    if (diff < 0) diff = 0;

    const days = Math.floor(diff / (1000 * 60 * 60 * 24));
    const hours = Math.floor((diff / (1000 * 60 * 60)) % 24);
    const mins = Math.floor((diff / (1000 * 60)) % 60);
    const secs = Math.floor((diff / 1000) % 60);

    document.getElementById("days").innerText = String(days).padStart(2, "0");
    document.getElementById("hours").innerText = String(hours).padStart(2, "0");
    document.getElementById("mins").innerText = String(mins).padStart(2, "0");
    document.getElementById("secs").innerText = String(secs).padStart(2, "0");
}

updateCountdown();
setInterval(updateCountdown, 1000);

function updateProgress() {

    const now = new Date();

    const startTime = new Date(now.getFullYear(), 0, 1); 
    const eventTime = new Date(now.getFullYear(), 5, 26, 18, 0, 0);

    if (now > eventTime) {
        eventTime.setFullYear(eventTime.getFullYear() + 1);
        startTime.setFullYear(startTime.getFullYear() + 1);
    }

    const totalTime = eventTime - startTime;
    const passedTime = now - startTime;

    let percent = (passedTime / totalTime) * 100;

    if (percent < 0) percent = 0;
    if (percent > 100) percent = 100;

    document.getElementById("progressBar").style.width = percent + "%";
    document.getElementById("progressText").innerText = percent.toFixed(1) + "%";
}

updateProgress();
setInterval(updateProgress, 60000);

</script>
